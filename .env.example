# Local PostgreSQL/PostGIS
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bridge_explorer?schema=public"

# Optional: direct connection URL for hosted Prisma migration workflows.
# Supabase projects often provide a pooled DATABASE_URL and a direct connection URL.
DIRECT_URL=""

# Optional: separate shadow database for Prisma migrate dev.
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bridge_explorer_shadow?schema=public"
